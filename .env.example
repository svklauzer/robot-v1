# ============================================================================
# robot-v1 — пример переменных окружения.
# Скопируй в .env и заполни. РЕАЛЬНЫЙ .env в git НЕ коммитится (см. .gitignore).
# В проде значения задаются в Render Dashboard, а не в этом файле.
# Здесь только основные переменные; тюнинг-параметры имеют дефолты в config.py.
# ============================================================================

# ── APP ─────────────────────────────────────────────────────────────────────
APP_ENV=development                 # production на Render
JWT_SECRET=                         # openssl rand -hex 32  /  python -c "import secrets;print(secrets.token_hex(32))"
NEXT_PUBLIC_API_URL=http://localhost:8000
CORS_ORIGINS=                       # прод-домен дашборда, напр. https://robot-web-xxxx.onrender.com

OWNER_EMAIL=
OWNER_PASSWORD=                     # сильный пароль, не дефолтный
OWNER_API_TOKEN=                    # openssl rand -hex 32

# ── DATABASE ──────────────────────────────────────────────────────────────
# Локально — split-переменные; на Render выставляется DATABASE_URL (connectionString).
POSTGRES_DB=robot
POSTGRES_USER=robot
POSTGRES_PASSWORD=robot
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=                       # если задан — переопределяет POSTGRES_* выше
DB_AUTO_CREATE_SCHEMA=true          # ОБЯЗАТЕЛЬНО false в production (схему создаёт Alembic)

REDIS_URL=redis://localhost:6379

# ── HTX API ─────────────────────────────────────────────────────────────────
HTX_API_KEY=
HTX_API_SECRET=
HTX_MARKET_TYPE=spot
HTX_SYMBOLS=BTC/USDT,ETH/USDT,SOL/USDT
HTX_PROXY_URL=

# ── TELEGRAM ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=                 # @BotFather
TELEGRAM_OWNER_CHAT_ID=0
TELEGRAM_FREE_SIGNALS_CHAT_ID=0
TELEGRAM_VIP_SIGNALS_CHAT_ID=0
TELEGRAM_PROXY_URL=
TELEGRAM_CONNECT_TIMEOUT=15.0
TELEGRAM_READ_TIMEOUT=30.0

# ── TRADING MODE (paper для старта) ──────────────────────────────────────────
ROBOT_MODE=paper                    # paper → live_shadow → live
TRADING_MODE=paper_signal           # paper_trade → live_limited → live
ENABLE_LIVE_ORDERS=false            # true только после прохождения validation gates
MARKET_TYPE=spot
ENABLE_FUTURES=false

# ── RISK MANAGEMENT (консервативно для старта) ────────────────────────────────
RISK_EQUITY_USDT=950.0
RISK_PER_TRADE_PCT=0.5
MAX_OPEN_POSITIONS=3
MAX_ACTIVE_SIGNALS=4
MAX_DAILY_LOSS_PCT=3
MAX_DRAWDOWN_PCT=15

# ── ML OUTCOMES / VALIDATION ──────────────────────────────────────────────────
TRADE_OUTCOMES_PATH=storage/ml/trade_outcomes.jsonl   # на Render: /app/storage/ml/trade_outcomes.jsonl
VALIDATION_MIN_CLOSED_SIGNALS=200

# ── FUNDING ARBITRAGE ─────────────────────────────────────────────────────────
ENABLE_FUNDING_ARB=false            # требует ENABLE_FUTURES=true
FUNDING_ARB_SYMBOLS=BTC/USDT,ETH/USDT
FUNDING_ARB_AUTO_OPEN_PAPER=true

# ── MISC ──────────────────────────────────────────────────────────────────────
NEWS_ENABLED=true
MARKET_CONNECTIVITY_MAX_LATENCY_MS=15000
EXCHANGE_RECONCILIATION_ENABLED=false
