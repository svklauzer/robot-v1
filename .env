# =========================
# APP
# =========================
APP_ENV=development
JWT_SECRET=change_me_long_random_secret

NEXT_PUBLIC_API_URL=http://localhost:8000

OWNER_EMAIL=admin@example.com
OWNER_PASSWORD=admin123456


# =========================
# DATABASE
# =========================
POSTGRES_DB=robot
POSTGRES_USER=robot
POSTGRES_PASSWORD=robot
POSTGRES_HOST=db
POSTGRES_PORT=5432

REDIS_URL=redis://redis:6379/0


# =========================
# HTX API
# =========================
HTX_API_KEY=your_new_htx_api_key
HTX_API_SECRET=your_new_htx_api_secret

# На текущем этапе работаем безопасно через spot-контекст
HTX_MARKET_TYPE=spot

# Активы для анализа
HTX_SYMBOLS=BTC/USDT,ETH/USDT,SOL/USDT,XRP/USDT,DOGE/USDT,ADA/USDT,LINK/USDT,AVAX/USDT,LTC/USDT,DOT/USDT,TRX/USDT,TON/USDT

ALLOW_MARKET_MOCK=false

# =========================
# TELEGRAM
# =========================
TELEGRAM_BOT_TOKEN=8782927095:AAHZ-U4dObtwVT1NX1WNT0gk61sfaQK2c9Y

# Личный чат владельца
TELEGRAM_OWNER_CHAT_ID=1832004802

# Старое поле оставляем для совместимости, направляем в VIP
TELEGRAM_SIGNALS_CHAT_ID=-1003946873279

# FREE канал
TELEGRAM_FREE_SIGNALS_CHAT_ID=-1003922573548

# VIP канал
TELEGRAM_VIP_SIGNALS_CHAT_ID=-1003946873279


# =========================
# NEWS
# =========================
NEWS_ENABLED=true


# =========================
# ROBOT BASIC MODE
# =========================
ROBOT_MODE=paper

# paper_signal = только сигналы
# paper_trade  = бумажные сделки с виртуальными позициями
# live_signal  = живые сигналы, без реальных ордеров
# live_trade   = реальные ордера
TRADING_MODE=paper_trade

# Жёсткий предохранитель: реальные ордера запрещены
ENABLE_LIVE_ORDERS=false


# =========================
# SIGNAL QUALITY PROFILE
# =========================

# SIGNAL_PROFILE=balanced
SIGNAL_PROFILE=learning
ALLOW_WEAK_VOLUME_TREND_ENTRIES=true
MIN_TREND_CONTINUATION_SCORE=62
MIN_TREND_STRUCTURE_SCORE=16


# =========================
# MARKET MODE
# =========================
# Для dev/paper сейчас используем spot market data.
# Short разрешён только как paper-сигнал/симуляция, без live futures orders.
MARKET_TYPE=spot
HTX_MARKET_TYPE=spot
EXECUTION_MARKET=spot
ENABLE_FUTURES=false
FUTURES_LEVERAGE=1
FUTURES_MARGIN_MODE=isolated

ALLOW_SHORTS=true
SHORT_ALERT_THROTTLE_MINUTES=60

# =========================
# RISK MANAGEMENT
# =========================
MAX_DAILY_LOSS_PCT=3
MAX_DRAWDOWN_PCT=15
MAX_OPEN_POSITIONS=4
RISK_PER_TRADE_PCT=0.5
MAX_POSITION_MARGIN_PCT=0.35
MIN_NET_PNL_TP1_USDT=2.5
MIN_NET_PNL_TP2_USDT=6.0
LEVELS_ENTRY_TF=5m
LEVELS_SIGNAL_TF=15m
LEVELS_CONTEXT_TF=1h
LEVELS_STOP_ATR_MULT=1.8
LEVELS_MIN_STOP_PCT=0.35
LEARNING_SETUP_MIN_SCORE=62
LEARNING_SETUP_MIN_TREND_ALIGNMENT=45
LEARNING_SETUP_MIN_VOLUME_CONFIRMATION=6
MIN_PROTECTIVE_EXIT_PCT=0.20
MIN_POST_TP1_EXIT_PCT=0.35

# =========================
# EXPOSURE / ACTIVE SIGNALS
# =========================
MAX_ACTIVE_SIGNALS=4
MAX_ACTIVE_SIGNALS_PER_SYMBOL=1
RISK_EQUITY_USDT=950
MAX_USED_MARGIN_PCT=0.85


# =========================
# FEES / COST ENGINE
# =========================
# Spot fees
SPOT_TAKER_FEE=0.002
SPOT_MAKER_FEE=0.002

# Futures / USDT perpetual fees
# Пока не используются, потому что ENABLE_FUTURES=false
FUTURES_TAKER_FEE=0.0005
FUTURES_MAKER_FEE=0.0002

# Буферы затрат
FUNDING_BUFFER_PCT=0.0003
SLIPPAGE_BUFFER_PCT=0.0005


# =========================
# TRAILING STOP
# =========================
# Пока будет использоваться только в будущей bot-side логике,
# не как native HTX trailing order.
ENABLE_TRAILING_STOP=true
TRAILING_AFTER_TP1=true
TRAILING_CALLBACK_PCT=0.4


# =========================
# AFFILIATE / VIP FUNNEL
# =========================
HTX_AFFILIATE_LINK=https://www.htx.com.ph/invite/ru-ru/1f?invite_code=b2a67223
AFFILIATE_FREE_VIP_DAYS=30
VIP_INVITE_LINK=https://t.me/+sBT3LPXE8qUxY2Ni
